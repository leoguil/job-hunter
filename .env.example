# ══════════════════════════════════════════════════════
# Job Hunter — Variables d'environnement backend
# Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────
# Supabase Dashboard → Project Settings → API

# URL du projet (ex: https://abcdef.supabase.co)
SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co

# Clé publishable / anon (publique — commence par sb_publishable_ ou eyJ)
SUPABASE_PUBLISHABLE_KEY=VOTRE_PUBLISHABLE_KEY

# ── Base de données ───────────────────────────────────
# Supabase Dashboard → Project Settings → Database
# Choisir "Connection string" → mode "Session" (port 5432)
# Remplacer [YOUR-PASSWORD] par le mot de passe DB

DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.VOTRE_PROJECT_REF.supabase.co:5432/postgres
